# ─── Acuérdate! — Backend MVP ───────────────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# .env nunca se versiona. Este archivo sí.

# ─── Obligatorio ─────────────────────────────────────────────────────────────

# API key de Google Maps (Places API habilitada)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Parámetros operativos del motor de cobertura ────────────────────────────
# Heurísticas iniciales del MVP. Revisar y ajustar en Fase 4.

# Cobertura mínima para que una tienda especialista gane sobre el supermercado.
SPECIALIST_COVERAGE_THRESHOLD=0.85

# Tamaño máximo de lista para activar una tienda especialista como recomendación principal.
# Listas más largas van al supermercado. Heurística inicial: revisar en Fase 4.
SPECIALIST_MAX_ITEMS=6

# Cobertura mínima para que una tienda especialista aparezca como parada complementaria opcional.
OPTIONAL_COVERAGE_THRESHOLD=0.50

# ─── Parámetros operativos de búsqueda en Maps ───────────────────────────────

# Radio de búsqueda en metros. Valor inicial: 1500m. Revisar en Fase 4.
RADIUS_METERS=1500

# ─── Rutas internas ──────────────────────────────────────────────────────────

# Ruta al diccionario de productos, relativa a la raíz del proyecto.
PRODUCTS_PATH=data/products.json

# ─── Red y timeouts ──────────────────────────────────────────────────────────

# Timeout en segundos para llamadas externas (Google Maps API).
REQUEST_TIMEOUT_SECONDS=10
